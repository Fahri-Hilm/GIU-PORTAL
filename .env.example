# Supabase (fill with your project credentials to enable real backend).
# If left empty, the app runs in MOCK mode with seeded data (no persistence beyond localStorage).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase service role key (server-only, used for storage uploads). NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=""

# App URL (auto-detected in most environments; used for OAuth callbacks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
